# ── Ollama ────────────────────────────────────────────────────────────────────
# Endpoint for Ollama. Default assumes it runs on the same machine.
# If Ollama runs on a different host, change to its IP:
#   OLLAMA_BASE=http://192.168.1.50:11434
OLLAMA_BASE=http://127.0.0.1:11434

# Main conversational + vision model.
# Adjust for your VRAM — see README for model recommendations by GPU size.
OLLAMA_MODEL=llama3.3:70b

# Background summarisation model — runs on CPU, never touches VRAM.
OLLAMA_SUMMARY_MODEL=llama3.2:3b

# How long to keep the main model loaded in VRAM after the last request.
OLLAMA_KEEP_ALIVE=15m

# Context window size. 8192 is a good default. Increase to 16384 if you have headroom.
OLLAMA_NUM_CTX=8192

# ── Music player ──────────────────────────────────────────────────────────────
# Path to ffmpeg binary. Use forward slashes on Windows.
# Leave as "ffmpeg" if ffmpeg is in your system PATH.
# Example: FFMPEG_PATH=C:/tools/ffmpeg/bin/ffmpeg.exe
FFMPEG_PATH=ffmpeg

# Path to yt-dlp binary. Leave as "yt-dlp" if it is in your system PATH.
# Example: YTDLP_PATH=C:/tools/yt-dlp.exe
YTDLP_PATH=yt-dlp

# ── Vector robot ──────────────────────────────────────────────────────────────
# Your Vector's ESN (serial number) — found on the underside of the robot
# or in the wire-pod web UI at http://localhost:8080
VECTOR_SERIAL=YOUR_VECTOR_SERIAL_HERE

# ── CORS (Pi dashboard) ───────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call vector-ai.
# Add your Pi's LAN IP and Tailscale IP so the Vector card works remotely.
# Example: CORS_ORIGINS=http://192.168.1.50:8082,http://100.xx.xx.xx:8082
CORS_ORIGINS=

# ── Tornado dashboard (Pi) ────────────────────────────────────────────────────
# Set in the Pi's environment, not here. The tornado dashboard reads this to
# call vector-ai for weather announces and the Vector card.
# VECTOR_AI_URL=http://YOUR_WINDOWS_TAILSCALE_IP:8000
